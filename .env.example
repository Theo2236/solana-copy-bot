# Helius (RPC + webhooks)
HELIUS_API_KEY=

# Upstash Redis (productie state)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel cron beveiliging
CRON_SECRET=

# Dashboard wachtwoord (optioneel, aanbevolen in prod)
DASHBOARD_PASSWORD=

# Bot modus: dry_run (default) of live
BOT_MODE=dry_run

# Alleen voor live trading — base58 private key van aparte bot-wallet
BOT_WALLET_PRIVATE_KEY=

# Optioneel: Helius webhook secret
HELIUS_WEBHOOK_SECRET=

# Publieke app-URL (voor webhook registratie)
NEXT_PUBLIC_APP_URL=
