# Helius (RPC + webhooks)
HELIUS_API_KEY=

# Upstash Redis (productie state)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel cron beveiliging
CRON_SECRET=

# Dashboard wachtwoord (optioneel, aanbevolen in prod)
DASHBOARD_PASSWORD=

# Bot modus: dry_run (default) of live
BOT_MODE=dry_run

# Copy size: conviction (schaal met % wallet-inzet target) of fixed
COPY_SIZE_MODE=conviction
# Baseline: bij deze % wallet-inzet van target = TRADE_SIZE_SOL (0.1 = 10%)
COPY_REFERENCE_CONVICTION_PCT=0.1
MIN_COPY_TRADE_SOL=0.02
MAX_COPY_TRADE_SOL=1.0
TRADE_SIZE_SOL=0.05

# Alleen voor live trading — base58 private key van aparte bot-wallet
BOT_WALLET_PRIVATE_KEY=

# Optioneel: Helius webhook secret
HELIUS_WEBHOOK_SECRET=

# Publieke app-URL (voor webhook registratie)
NEXT_PUBLIC_APP_URL=

# Risicobeheer
MAX_OPEN_POSITIONS=3
STOP_LOSS_PCT=30
# 0 = uit — exit via target copy-sell (aanbevolen voor pump.fun)
TAKE_PROFIT_PCT=0
MIN_LIQUIDITY_USD=2000
MIN_TOKEN_AGE_HOURS=0
SLIPPAGE_BPS=300

# Auto-disable slechte targets (0 = uit)
TARGET_AUTO_DISABLE_MIN_TRADES=3
TARGET_AUTO_DISABLE_MAX_LOSS_SOL=-0.05
