# App
NEXT_PUBLIC_APP_URL=https://jouw-project.vercel.app
BOT_MODE=dry_run
BOT_ENABLED=true

# Bot wallet (alleen nodig voor live trading)
# Base58 secret key of JSON array [1,2,3,...]
BOT_WALLET_PRIVATE_KEY=

# Helius (RPC + webhooks + transaction history)
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=een-sterk-willekeurig-geheim

# Upstash Redis (persistent state op Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Cron beveiliging
CRON_SECRET=een-sterk-cron-geheim

# Optioneel: dashboard beveiligen
DASHBOARD_PASSWORD=

# Risico-instellingen
TRADE_SIZE_SOL=0.05
MAX_OPEN_POSITIONS=3
MAX_TRADES_PER_DAY=5
STOP_LOSS_PCT=30
TAKE_PROFIT_PCT=100
MAX_DRAWDOWN_EUR=20
MIN_LIQUIDITY_USD=50000
MIN_TOKEN_AGE_HOURS=1
SLIPPAGE_BPS=300
